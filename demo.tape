# README demo — regenerate with: sudo -v && vhs demo.tape
# Requires vhs (+ ttyd, ffmpeg): https://github.com/charmbracelet/vhs
Output demo.gif
Set Shell zsh
Set FontSize 28
Set Width 1100
Set Height 560
Set Padding 20
Sleep 1s
Type "sudo $(which hosts-blocker)"
Sleep 600ms
Enter
Sleep 1.2s
Type "1"
Sleep 500ms
Enter
Sleep 800ms
Type "reddit.com"
Sleep 600ms
Enter
Sleep 2s
Type "curl reddit.com"
Sleep 600ms
Enter
Sleep 5s
